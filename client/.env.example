# Скопируйте в client/.env.local и подставьте значения из вашего Supabase-проекта
# (Dashboard → Project Settings → API). Эти ключи ПУБЛИЧНЫЕ и безопасны для клиента.
#
# Без этих переменных сайт работает в офлайн-режиме (прогресс только в localStorage),
# авторизация и ИИ-проверка отключены.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
